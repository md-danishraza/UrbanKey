generator client {
  provider        = "prisma-client-js"
  // Add multiSchema to support your custom 'urbankey' schema
  previewFeatures = ["postgresqlExtensions", "multiSchema"]
}

datasource db {
  provider   = "postgresql"
  // Tell Prisma exactly which schema the extension is in
  extensions = [vector(map: "vector", schema: "urbankey")]
  // Define your active schemas
  schemas    = ["urbankey"]
}

model User {
  id         String   @id @default(cuid()) // We'll map Clerk user ID here
  email      String   @unique
  phone      String?  @unique
  fullName   String
  role       Role     @default(TENANT)
  isVerified Boolean  @default(false)
  avatarUrl  String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relations
  properties           Property[]         @relation("LandlordProperties")
  wishlist             Wishlist[]
  visits               VisitSchedule[]
  leads                Lead[]
  agreementsAsLandlord RentalAgreement[]  @relation("LandlordAgreements")
  agreementsAsTenant   RentalAgreement[]  @relation("TenantAgreements")
  analytics            AnalyticsEvent[]
  documents            UserDocument[]
  landlordAgreement    LandlordAgreement?

  // onboarding
  onboardingCompleted Boolean             @default(false) @map("onboarding_completed")
  onboardingProgress  OnboardingProgress?
  ChatHistory         ChatHistory[]

  @@map("users")
  @@schema("urbankey")
}

model UserDocument {
  id              String         @id @default(cuid())
  userId          String         @map("user_id")
  documentType    String         @map("document_type") // 'aadhar', 'pan', 'property', etc.
  fileUrl         String         @map("file_url")
  fileName        String         @map("file_name")
  fileSize        Int            @map("file_size")
  mimeType        String         @map("mime_type")
  status          DocumentStatus @default(PENDING)
  rejectionReason String?        @map("rejection_reason")
  uploadedAt      DateTime       @default(now()) @map("uploaded_at")
  verifiedAt      DateTime?      @map("verified_at")
  verifiedBy      String?        @map("verified_by")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, documentType])
  @@map("user_documents")
  @@schema("urbankey")
}

model OnboardingProgress {
  id             String    @id @default(cuid())
  userId         String    @unique @map("user_id")
  currentStep    String    @map("current_step")
  completedSteps Json      @default("[]")
  data           Json      @default("{}")
  completed      Boolean   @default(false)
  completedAt    DateTime? @map("completed_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("onboarding_progress")
  @@schema("urbankey")
}

// onboarding agreement
model LandlordAgreement {
  id           String   @id @default(cuid())
  userId       String   @unique @map("user_id")
  acceptedAt   DateTime @map("accepted_at")
  termsVersion String   @map("terms_version")
  ipAddress    String?  @map("ip_address")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("landlord_agreements")
  @@schema("urbankey")
}

model Property {
  id           String         @id @default(cuid())
  landlordId   String         @map("landlord_id")
  title        String
  description  String?
  bhk          BHKType
  rent         Float
  furnishing   FurnishingType
  tenantType   TenantType     @map("tenant_type")
  isActive     Boolean        @default(true) @map("is_active")
  isBroker     Boolean        @default(false) @map("is_broker")
  brokerageFee Float?         @map("brokerage_fee")

  // Address
  addressLine1 String  @map("address_line1")
  addressLine2 String? @map("address_line2")
  city         String
  state        String
  pincode      String

  // Location
  latitude  Float?
  longitude Float?

  // Indian amenities
  hasWater247    Boolean @default(false) @map("has_water_247")
  hasPowerBackup Boolean @default(false) @map("has_power_backup")
  hasIglPipeline Boolean @default(false) @map("has_igl_pipeline")

  // Metro info
  nearestMetroStation String? @map("nearest_metro_station")
  distanceToMetroKm   Float?  @map("distance_to_metro_km")

  // NEW: Occupancy fields
  isOccupied      Boolean   @default(false) @map("is_occupied")
  currentTenantId String?   @map("current_tenant_id")
  occupiedFrom    DateTime? @map("occupied_from")
  occupiedUntil   DateTime? @map("occupied_until")

  // Metadata
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  landlord   User               @relation("LandlordProperties", fields: [landlordId], references: [id])
  images     PropertyImage[]
  wishlists  Wishlist[]
  visits     VisitSchedule[]
  leads      Lead[]
  agreements RentalAgreement[]
  analytics  AnalyticsEvent[]
  embeddings PropertyEmbedding?

  @@map("properties")
  @@schema("urbankey")
}

model PropertyImage {
  id         String   @id @default(cuid())
  propertyId String   @map("property_id")
  imageUrl   String   @map("image_url")
  isPrimary  Boolean  @default(false) @map("is_primary")
  sortOrder  Int?     @map("sort_order")
  uploadedAt DateTime @default(now()) @map("uploaded_at")

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("property_images")
  @@schema("urbankey")
}

model Wishlist {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  propertyId String   @map("property_id")
  createdAt  DateTime @default(now()) @map("created_at")

  tenant   User     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([tenantId, propertyId])
  @@map("wishlists")
  @@schema("urbankey")
}

model VisitSchedule {
  id            String      @id @default(cuid())
  tenantId      String      @map("tenant_id")
  propertyId    String      @map("property_id")
  scheduledDate DateTime    @map("scheduled_date")
  scheduledTime String      @map("scheduled_time") // store as string "HH:MM"
  status        VisitStatus @default(PENDING)
  notes         String?
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  tenant   User     @relation(fields: [tenantId], references: [id])
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("visit_schedules")
  @@schema("urbankey")
}

model Lead {
  id            String        @id @default(cuid())
  propertyId    String        @map("property_id")
  tenantId      String        @map("tenant_id")
  contactMethod ContactMethod @default(WHATSAPP) @map("contact_method")
  message       String?
  status        LeadStatus    @default(NEW)
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant   User     @relation(fields: [tenantId], references: [id])

  @@map("leads")
  @@schema("urbankey")
}

// NEW: Rental Agreement Model
model RentalAgreement {
  id              String @id @default(cuid())
  agreementNumber String @unique @map("agreement_number")
  propertyId      String @map("property_id")
  tenantId        String @map("tenant_id")
  landlordId      String @map("landlord_id")

  // Agreement Details
  startDate       DateTime @map("start_date")
  endDate         DateTime @map("end_date")
  monthlyRent     Float    @map("monthly_rent")
  securityDeposit Float    @map("security_deposit")
  maintenanceFee  Float?   @map("maintenance_fee")
  noticePeriod    Int      @default(30) @map("notice_period")

  // Terms
  terms             String? @db.Text
  specialConditions String? @map("special_conditions") @db.Text

  // Status
  status AgreementStatus @default(DRAFT)

  // Signatures
  signedByTenant   Boolean   @default(false) @map("signed_by_tenant")
  signedByLandlord Boolean   @default(false) @map("signed_by_landlord")
  signedAt         DateTime? @map("signed_at")

  // Document
  pdfUrl       String? @map("pdf_url")
  signedPdfUrl String? @map("signed_pdf_url")

  // Metadata
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  property Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant   User      @relation("TenantAgreements", fields: [tenantId], references: [id])
  landlord User      @relation("LandlordAgreements", fields: [landlordId], references: [id])
  payments Payment[]

  @@unique([propertyId, tenantId, status])
  @@map("rental_agreements")
  @@schema("urbankey")
}

// NEW: Payment Model
model Payment {
  id          String @id @default(cuid())
  agreementId String @map("agreement_id")

  // Payment Details
  amount      Float
  month       Int? // Month number (1,2,3... for rent payments)
  year        Int? // Year for the payment
  paymentDate DateTime @map("payment_date")
  dueDate     DateTime @map("due_date")

  // Payment Type
  type PaymentType @default(RENT)

  // Status
  status PaymentStatus @default(PENDING)

  // Additional Info
  description   String?
  receiptUrl    String?       @map("receipt_url")
  transactionId String?       @map("transaction_id")
  paymentMethod PaymentMethod @default(CASH)

  // Metadata
  recordedBy String?  @map("recorded_by") // userId who recorded this
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relations
  agreement RentalAgreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)

  @@map("payments")
  @@schema("urbankey")
}

model AnalyticsEvent {
  id         String   @id @default(cuid())
  eventType  String   @map("event_type")
  userId     String?  @map("user_id")
  propertyId String?  @map("property_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  user     User?     @relation(fields: [userId], references: [id])
  property Property? @relation(fields: [propertyId], references: [id])

  @@map("analytics_events")
  @@schema("urbankey")
}

// pgvector model for embeddings
model PropertyEmbedding {
  id         String                 @id @default(cuid())
  propertyId String                 @unique @map("property_id")
  content    String? // combined property text
  // FIX: Updated to 3072 to perfectly match gemini-embedding-001's output
  embedding  Unsupported("vector")?
  updatedAt  DateTime               @updatedAt @map("updated_at")

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("property_embeddings")
  @@schema("urbankey")
}

// chatbot
model ChatHistory {
  id                  String   @id @default(cuid())
  userId              String   @map("user_id")
  question            String   @db.Text
  answer              String   @db.Text
  relevantPropertyIds Json?    @map("relevant_property_ids")
  createdAt           DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("chat_history")
  @@schema("urbankey")
}

// Enums
enum Role {
  TENANT
  LANDLORD
  ADMIN

  @@schema("urbankey")
}

enum BHKType {
  ONE_BHK       @map("1BHK")
  TWO_BHK       @map("2BHK")
  THREE_BHK     @map("3BHK")
  FOUR_BHK_PLUS @map("4BHK+")

  @@schema("urbankey")
}

enum FurnishingType {
  UNFURNISHED
  SEMI_FURNISHED
  FULLY_FURNISHED

  @@schema("urbankey")
}

enum TenantType {
  FAMILY
  BACHELORS
  BOTH

  @@schema("urbankey")
}

enum VisitStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED

  @@schema("urbankey")
}

enum ContactMethod {
  WHATSAPP
  PHONE
  EMAIL

  @@schema("urbankey")
}

enum LeadStatus {
  NEW
  CONTACTED
  CONVERTED
  CLOSED

  @@schema("urbankey")
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED

  @@schema("urbankey")
}

// Enums for Agreement
enum AgreementStatus {
  DRAFT
  PENDING_SIGNATURE
  ACTIVE
  EXPIRED
  TERMINATED

  @@schema("urbankey")
}

// Enums for Payment
enum PaymentType {
  RENT
  SECURITY_DEPOSIT
  MAINTENANCE
  LATE_FEE
  OTHER

  @@schema("urbankey")
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  REFUNDED

  @@schema("urbankey")
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  UPI
  CHEQUE
  OTHER

  @@schema("urbankey")
}
